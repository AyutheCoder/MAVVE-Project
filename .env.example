# ══════════════════════════════════════════════════════════
# MAVVE — Multi-Agent Vernacular Validation Ecosystem
# Environment Configuration
# ══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
APP_NAME=MAVVE
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=true

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mavve:mavve_secret@localhost:5432/mavve_db
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ────────────────────────────────────────
# Options: "gemini" | "openai" | "openrouter"
LLM_PROVIDER=openrouter
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL_NAME=google/gemini-2.0-flash-001
LLM_TEMPERATURE=0.3

# ── WhatsApp Business API ────────────────────────────────
# Get these from Meta Business Suite → WhatsApp → API Setup
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=mavve_verify_token_2026
WHATSAPP_API_URL=https://graph.facebook.com/v21.0

# ── Bhashini API ─────────────────────────────────────────
# Get these from https://bhashini.gov.in/ulca/user/register
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in
# Set to true to use mock responses (no real API calls)
BHASHINI_MOCK_MODE=true

# ── Payment Gateway (Razorpay) ───────────────────────────
# Get these from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── MAVVE Agent Configuration ───────────────────────────
# P(RTO) threshold — orders above this are intercepted
RTO_RISK_THRESHOLD=0.65
# Maximum discount for prepaid conversion (%)
MAX_DISCOUNT_PERCENT=15
# Maximum conversation rounds before escalation
MAX_CONVERSATION_ROUNDS=5
# Session timeout in hours
SESSION_TIMEOUT_HOURS=24
# Minimum confidence to accept an address
ADDRESS_CONFIDENCE_THRESHOLD=0.85

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5175","http://localhost:3000"]
